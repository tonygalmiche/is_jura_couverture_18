<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Forme juridique -->
        <record model="ir.ui.view" id="is_forme_juridique_tree">
            <field name="name">is.forme.juridique.tree</field>
            <field name="model">is.forme.juridique</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="name"/>
                </list>
            </field>
        </record>
        <record model="ir.ui.view" id="is_forme_juridique_form">
            <field name="name">is.forme.juridique.form</field>
            <field name="model">is.forme.juridique</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record model="ir.actions.act_window" id="is_forme_juridique_action">
            <field name="name">Formes juridiques</field>
            <field name="res_model">is.forme.juridique</field>
            <field name="view_mode">list,form</field>
        </record>
        <record model="ir.ui.view" id="is_view_partner_form_hide_siret">
            <field name="name">is_view_partner_form_hide_siret</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="l10n_fr.res_partner_form_l10n_fr"/>
            <field name="arch" type="xml">
                <field name="siret" position="after">
                    <field name="is_forme_juridique_id"/>
                    <field name="is_capital_social"/>
                    <field name="is_lieu_rcs"/>
                    <field name="is_code_naf"/>
                </field>
            </field>
        </record>

        <!-- res.partner -->
        <!-- <record model="ir.ui.view" id="is_view_partner_form">
            <field name="name">is_view_partner_form</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <field name="function" position="before">
                </field>
            </field>
        </record>  -->
        <record id="is_view_partner_tree" model="ir.ui.view">
            <field name="name">res.partner.tree</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_tree"/>
            <field name="arch" type="xml">
                <field name="complete_name" position="after">
                    <field name="is_forme_juridique_id" optional="hide"/>
                    <field name="is_capital_social" optional="hide"/>
                    <field name="is_lieu_rcs" optional="hide"/>
                    <field name="is_code_naf" optional="hide"/>
                </field>
            </field>
        </record>
        <!-- <record id="is_view_res_partner_filter" model="ir.ui.view">
