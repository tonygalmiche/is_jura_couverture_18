<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Ajout du champ Objet sur la vue formulaire facture client -->
    <record id="view_move_form_is_objet" model="ir.ui.view">
        <field name="name">account.move.form.is_objet</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_title')]" position="after">
                <group invisible="move_type not in ('out_invoice', 'out_refund')">
                    <field name="is_objet" placeholder="Objet de la facture..."/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Ajout du champ Objet dans la vue liste -->
    <record id="view_invoice_tree_is_objet" model="ir.ui.view">
        <field name="name">account.invoice.list.is_objet</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <field name="invoice_date" position="before">
                <field name="is_objet" optional="show" string="Objet"/>
            </field>
        </field>
    </record>

    <!-- Ajout du champ Objet dans la vue recherche -->
    <record id="view_invoice_filter_is_objet" model="ir.ui.view">
        <field name="name">account.invoice.filter.is_objet</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <field name="ref" position="after">
                <field name="is_objet" string="Objet"/>
            </field>
        </field>
    </record>
</odoo>
